ENV=production
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=7860

# Comma-separated. Add your Vercel frontend URL here.
CORS_ORIGINS=https://your-app.vercel.app

# Neon PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require&channel_binding=require

# HuggingFace Hub model repo ID (e.g. yourusername/moodmirror-roberta-3class)
# Set this on HF Spaces so the model is downloaded from the Hub at startup.
EMOTION_MODEL_HUB_ID=yourusername/moodmirror-roberta-3class

EMOTION_MAPPING_PATH=app/assets/emotion_mapping_3class.json

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
