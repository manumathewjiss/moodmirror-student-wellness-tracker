ENV=production
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=7860

# Comma-separated. Add your Vercel frontend URL here.
CORS_ORIGINS=https://your-app.vercel.app

# Neon PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require&channel_binding=require

# HuggingFace Hub model repo ID (e.g. yourusername/aimooddiary-roberta-3class)
# Set this on HF Spaces so the model is downloaded from the Hub at startup.
EMOTION_MODEL_HUB_ID=yourusername/aimooddiary-roberta-3class

EMOTION_MAPPING_PATH=app/assets/emotion_mapping_3class.json

# OpenAI (required for Diary LLM text + Whisper voice-to-text on /api/v1/speech/transcribe)
# Replace the placeholder: copy this file to `.env` locally, or set secrets on HF/Vercel/etc.
# Keys: https://platform.openai.com/api-keys — never commit a real key to git.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional; default whisper-1 (Diary voice-to-text).
OPENAI_WHISPER_MODEL=whisper-1
